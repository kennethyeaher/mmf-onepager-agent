# Copy this file to .env and fill in your keys, or export these in your shell.
# The .env file is listed in .gitignore so it never gets committed.

# Anthropic API key. Web search must be enabled by your org admin in the Console.
ANTHROPIC_API_KEY=sk-ant-...

# HubSpot private app token with CRM read scopes:
#   crm.objects.companies.read, crm.objects.contacts.read, crm.objects.notes.read
HUBSPOT_TOKEN=pat-...
